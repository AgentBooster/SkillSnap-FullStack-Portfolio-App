@page "/login"
@inject SkillSnap.Client.Services.AuthService AuthService

<h3>Login</h3>

<div>
    <label>Email</label>
    <input @bind="email" type="email" class="form-control" />
</div>
<div>
    <label>Password</label>
    <input @bind="password" type="password" class="form-control" />
</div>
<button class="btn btn-primary mt-2" @onclick="HandleLogin">Login</button>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="text-danger mt-2">@errorMessage</p>
}

@code {
    private string email;
    private string password;
    private string errorMessage;

    private async Task HandleLogin()
    {
        var token = await AuthService.LoginAsync(email, password);
        if (token != null)
        {
            errorMessage = "Login successful!";
            // In a real app we would call LocalStorage and AuthenticationStateProvider here.
        }
        else
        {
            errorMessage = "Invalid login attempt.";
        }
    }
}

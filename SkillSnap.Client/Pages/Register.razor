@page "/register"
@inject SkillSnap.Client.Services.AuthService AuthService

<h3>Register</h3>

<div>
    <label>Email</label>
    <input @bind="email" type="email" class="form-control" />
</div>
<div>
    <label>Password</label>
    <input @bind="password" type="password" class="form-control" />
</div>
<button class="btn btn-success mt-2" @onclick="HandleRegister">Register</button>

@if (!string.IsNullOrEmpty(message))
{
    <p class="text-info mt-2">@message</p>
}

@code {
    private string email;
    private string password;
    private string message;

    private async Task HandleRegister()
    {
        var success = await AuthService.RegisterAsync(email, password);
        if (success)
        {
            message = "Registration successful! You can now login.";
        }
        else
        {
            message = "Registration failed.";
        }
    }
}
